{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/" },
    { "source": "/overview", "destination": "/" },
    { "source": "/terminal", "destination": "/" },
    { "source": "/liquidity-map", "destination": "/" },
    { "source": "/flows", "destination": "/" },
    { "source": "/developers", "destination": "/" },
    { "source": "/support", "destination": "/" }
  ]
}
